			"net.plarke.bee_statistics.BeeStatistics"
		],
		"fabric-datagen": [
			"net.plarke.bee_statistics.BeeStatisticsDataGenerator"
		],
		"client": [
			"net.plarke.bee_statistics.BeeStatisticsClient"
		]
	},
	"mixins": [
		"bee-statistics.mixins.json"
	],
	"depends": {
