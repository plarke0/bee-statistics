{
	"schemaVersion": 1,
	"id": "bee-statistics",
	"version": "${version}",
	"name": "Bee Statistics",
	"description": "A mod for tracking the various statistics of beehives and honey production.",
	"authors": [
		"plarke"
	],
	"contact": {
		"homepage": "https://plarke.net/",
		"sources": "https://github.com/plarke0/bee-statistics"
	},
	"license": "CC0-1.0",
	"icon": "assets/bee-statistics/icon.png",
	"environment": "*",
	"entrypoints": {
